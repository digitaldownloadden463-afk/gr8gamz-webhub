{
  "name": "gr8gamz-webhub",
  "version": "2.0.1",
  "description": "GR8 GAMZ browser-game hub with original, curated partner, and GameMonetize catalogue games",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app components lib scripts src/data src/lib/activeRoutes.js src/lib/crawl.js src/lib/partnerFeedResolver.js next.config.js eslint.config.mjs --max-warnings=0",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "validate:games": "node scripts/validate-games.mjs",
    "validate:active-routes": "node scripts/validate-active-routes.mjs",
    "test:security": "node scripts/test-security.mjs",
    "audit:releases": "node scripts/run-release-audits.mjs",
    "type-check": "tsc --noEmit",
    "audit:v35-8-stabilise": "node scripts/audit-v35-8-stabilise.mjs",
    "audit:v35-9-security-upgrade": "node scripts/audit-v35-9-security-upgrade.mjs",
    "check": "pnpm type-check && pnpm lint && pnpm validate:games && pnpm validate:active-routes && pnpm test:security && pnpm audit:releases && pnpm build"
  },
  "dependencies": {
    "lucide-react": "0.468.0",
    "next": "16.2.10",
    "pg": "^8.13.1",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.17.6",
    "@types/react": "18.3.12",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.10",
    "prettier": "^3.1.0",
    "typescript": "5.6.3"
  }
}
