# GR8 GAMZ Environment Configuration
# Copy this file to .env.local and fill in your values

# Analytics (optional)
NEXT_PUBLIC_GA_ID=

# API endpoints (if backend integration needed)
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Server-side Passport and moderation storage
GR8_SESSION_SECRET=
GR8_ADMIN_KEY=
GR8_DATABASE_URL=
GR8_DATABASE_CA_CERT=
GR8_BACKEND_ENDPOINT=
GR8_BACKEND_TOKEN=

# Development-only fallbacks; keep false in production
GR8_ALLOW_EPHEMERAL_AUTH=false
GR8_ALLOW_EPHEMERAL_BACKEND=false

# IndexNow submissions (server-only; use a long random token)
INDEXNOW_KEY=470561d472ec49aca5a704b6d8a3eac0
INDEXNOW_SUBMIT_TOKEN=

# Feature flags
NEXT_PUBLIC_ENABLE_LEADERBOARD=true
NEXT_PUBLIC_ENABLE_PASSPORT=false
